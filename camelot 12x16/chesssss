Style

body {
    font-family: sans-serif;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    background-color: #f4f4f4;
    margin: 0;
    padding: 20px;
    box-sizing: border-box;
}

h1, h2 {
    color: #333;
}

#board-container {
    margin-bottom: 30px;
    border: 2px solid #333;
    box-shadow: 0 0 15px rgba(0,0,0,0.2);
    overflow: hidden; /* Para conter o tabuleiro se ele for maior que a tela */
}

#board {
    display: grid;
    /* O tamanho do grid será definido dinamicamente pelo JavaScript */
    background-color: #e0e0e0; /* Cor de fundo base para o tabuleiro */
}

.square {
    width: 60px;  /* Tamanho de cada casa */
    height: 60px; /* Tamanho de cada casa */
    display: flex;
    align-items: center;
    justify-content: center;
    box-sizing: border-box;
    border: 1px solid #ccc; /* Borda sutil */
    background-color: #f0f0f0; /* Cor padrão das casas */
}

.square.light {
    background-color: #f0f0f0; /* Casas claras */
}

.square.dark {
    background-color: #a0a0a0; /* Casas escuras */
}

/* Estilo para as peças (imagens JPG) */
.piece-img {
    width: 80%; /* Ajusta o tamanho da imagem da peça dentro da casa */
    height: 80%;
    object-fit: contain; /* Mantém a proporção da imagem */
    cursor: grab; /* Indica que pode ser arrastada */
    user-select: none; /* Impede a seleção da imagem ao arrastar */
    display: block; /* Remove espaço extra abaixo da imagem */
}

#piece-selector {
    text-align: center;
    margin-bottom: 20px;
    background-color: #fff;
    padding: 20px;
    border-radius: 8px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
}

#pieces-list {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 15px;
    margin-top: 15px;
    margin-bottom: 15px;
}

.piece-option {
    border: 1px dashed #ccc;
    padding: 10px;
    border-radius: 5px;
    cursor: grab;
    background-color: #f9f9f9;
    transition: background-color 0.2s ease;
    display: flex;
    flex-direction: column;
    align-items: center;
}

.piece-option:hover {
    background-color: #e9e9e9;
}

.piece-option img {
    width: 40px;
    height: 40px;
    object-fit: contain;
    user-select: none;
}

#reset-button {
    padding: 10px 20px;
    background-color: #ff6666;
    color: white;
    border: none;
    border-radius: 5px;
    cursor: pointer;
    font-size: 16px;
    transition: background-color 0.2s ease;
}

#reset-button:hover {
    background-color: #e65c5c;
}


