}

/* Estilo para a peça genérica */
.piece {
    width: 40px;  /* Tamanho da peça */
    height: 40px; /* Tamanho da peça */
    border-radius: 50%;
    
    /* Configurações para centralizar a peça NO CENTRO DA SUA PRÓPRIA DIV */
    display: flex;
    align-items: center;
    justify-content: center;

    font-weight: bold;
    cursor: grab;
    box-shadow: 0 2px 5px rgba(0,0,0,0.2);
    box-sizing: border-box;
    border: 3px solid transparent;
    font-size: 24px;
    user-select: none;

    /* A posição da peça será controlada pelo JavaScript, 
       mas estas propriedades a mantêm no centro de sua própria DIV. */
}

/* Estilo específico para o Rei */
.piece.king {
    background-color: #d4af37;
    color: #333;
    border-color: #a08000;
}

/* Estilo específico para o Peão Branco */
.piece.pawn.white {
    background-color: #ffffff;
    color: #333;
    border-color: #d4af37;
}

/* Estilo específico para o Peão Preto */
.piece.pawn.black {
    background-color: #222222;
    color: #fff;
    border-color: #000;
}

/* O tabuleiro agora será um grid que cria as INTERSEÇÕES */
#board {
    display: grid;
    /* Criamos 9 linhas de INTERSEÇÕES (9x9).
       Entre cada interseção, temos um "espaço" que será o quadrado visual.
       Se temos 9 interseções, temos 8 "espaços" visuais entre elas.
       Vamos dimensionar as casas para serem um pouco maiores que as peças.
    */
    grid-template-columns: repeat(8, 50px); /* 8 "espaços" visuais entre as 9 colunas de interseções */
    grid-template-rows: repeat(8, 50px);    /* 8 "espaços" visuais entre as 9 linhas de interseções */
    
    /* Para simular as linhas de interseção visuais, podemos usar um tabuleiro com bordas mais grossas */
    border: 2px solid #333; /* Borda geral do tabuleiro */
    width: calc(8 * 50px + 2 * 2px); /* Largura total: 8 espaços * tamanho + borda */
    height: calc(8 * 50px + 2 * 2px); /* Altura total: 8 espaços * tamanho + borda */
    
    box-shadow: 0 0 10px rgba(0,0,0,0.1);
    background-color: #ccc; /* Cor de fundo do tabuleiro */
    position: relative; /* Necessário para posicionar os elementos filhos (peças) */
}

/* As casas agora representam os ESPAÇOS entre as interseções */
.square {
    box-sizing: border-box;
    background-color: transparent; /* As casas em si não têm cor, são os pontos de interseção que importam */
    border: 1px solid #ddd; /* Borda sutil para delimitar os "espaços" */
    display: flex; /* Para ajudar a centralizar virtualmente o que vier dentro */
    align-items: center;
    justify-content: center;
    /* Não usamos mais cores light/dark para as casas, as linhas são as que importam visualmente */
}

/* Adicionando as linhas visuais */
/* Linhas verticais (colunas) */
#board .square:nth-child(8n+1) { /* Cada primeira coluna em uma linha */
    border-left-color: #333;
    border-left-width: 2px; /* Linha mais grossa para borda esquerda */
}
#board .square:nth-child(8n+2),
#board .square:nth-child(8n+3),
#board .square:nth-child(8n+4),
#board .square:nth-child(8n+5),
#board .square:nth-child(8n+6),
#board .square:nth-child(8n+7) {
    border-left-color: #888; /* Linhas mais finas */
}
#board .square:nth-child(8n+8) { /* Borda direita do tabuleiro */
    border-right-color: #333;
    border-right-width: 2px;
}

/* Linhas horizontais (linhas) */
/* Para isso, precisamos de um seletor que pegue grupos de 8 elementos */
/* O seletor :nth-child(8n+k) funciona para colunas, para linhas, precisamos aplicar a cada grupo */

/* Para linhas, vamos usar uma abordagem mais explícita ou um pseudo-elemento se necessário */
/* Uma forma mais simples é focar no 'board' como um todo e adicionar bordas */
#board {
    border-left: 2px solid #333;
    border-top: 2px solid #333;
    border-right: 2px solid #333;
    border-bottom: 2px solid #333;
}

/* Para as linhas internas horizontais, precisaremos aplicar em cada .square */
/* Isto pode ficar complexo com N*N grid. */
/* Vamos simplificar: o JavaScript vai criar elementos de 'line' ou usar pseudo-elementos para as linhas */
/* Ou, se preferir, manter as casas com cor e ajustar o posicionamento das peças */

/* Vamos reconsiderar: Uma abordagem mais fácil é ter um grid de 9x9 INTERSEÇÕES */

/* --- Nova Abordagem CSS: Grid de 9x9 de Interseções --- */
#board {
    display: grid;
    grid-template-columns: repeat(9, 50px); /* 9 colunas de INTERSEÇÕES */
    grid-template-rows: repeat(9, 50px);    /* 9 linhas de INTERSEÇÕES */
    
    width: calc(9 * 50px); /* 9 * 50px = 450px */
    height: calc(9 * 50px);
    
    border: 2px solid #333; /* Borda geral */
    background-color: #ccc; /* Cor de fundo */
    box-shadow: 0 0 10px rgba(0,0,0,0.1);
    position: relative; /* Para posicionamento absoluto das peças */
    padding: 10px; /* Espaço para as linhas externas */
    box-sizing: content-box; /* Padding não afeta o tamanho total declarado */
}

/* As "casas" agora são os pontos de interseção */
.square {
    width: 100%; /* Ocupa toda a célula do grid */
    height: 100%;
    display: flex; /* Usa flex para centralizar a peça que será adicionada a esta INTERSEÇÃO */
    align-items: center;
    justify-content: center;
    box-sizing: border-box;
    background-color: transparent; /* As interseções não têm cor própria, apenas linhas */
    border: none; /* Remove bordas de quadrado */
    
    /* As linhas serão adicionadas via pseudo-elementos ou com JavaScript */
}

/* Pseudo-elementos para simular as linhas */
.square::before, .square::after {
    content: '';
    position: absolute;
    background-color: #888; /* Cor das linhas */
    z-index: 0; /* Ficam atrás das peças */
}

/* Linhas verticais */
.square::before {
    width: 1px; /* Espessura da linha vertical */
    height: 100%;
    left: 50%; /* Centraliza horizontalmente dentro da célula */
    transform: translateX(-50%); /* Ajuste fino para centralizar perfeitamente */
    background-color: #888; /* Cor da linha */
}

/* Linhas horizontais */
.square::after {
    width: 100%;
    height: 1px; /* Espessura da linha horizontal */
    top: 50%; /* Centraliza verticalmente dentro da célula */
    transform: translateY(-50%); /* Ajuste fino para centralizar perfeitamente */
    background-color: #888; /* Cor da linha */
}

/* Remover linhas desnecessárias nas bordas do tabuleiro */
/* Linhas verticais extremas (coluna 0 e coluna 8) */
.square:nth-child(9n+1)::before { /* Primeira coluna */
    left: 0; /* Alinha com a borda esquerda do #board */
    background-color: #333; /* Linha mais grossa/escura na borda */
    width: 2px; /* Espessura da borda */
}
.square:nth-child(9n+9)::before { /* Última coluna */
    right: 0; /* Alinha com a borda direita do #board */
    background-color: #333; /* Linha mais grossa/escura na borda */
    width: 2px;
}

/* Linhas horizontais extremas (linha 0 e linha 8) */
/* Para isso, precisamos percorrer as 9 linhas */
/* Selecionar todos os elementos da primeira linha (0 a 8) */
#board .square:nth-child(-n+9)::after { 
    top: 0; /* Alinha com a borda superior */
    background-color: #333;
    height: 2px;
}
/* Selecionar todos os elementos da última linha (72 a 80) */
#board .square:nth-child(n+73)::after { /* 9*8 = 72. n+73 pegaria da 73ª posição em diante (última linha) */
    bottom: 0; /* Alinha com a borda inferior */
    background-color: #333;
    height: 2px;
}

/* Remover as linhas internas onde elas não devem aparecer */
/* Por exemplo, a linha horizontal no meio de uma "casa" que é uma interseção */
/* Se a peça ficar EXATAMENTE na interseção, não queremos a linha atravessando o centro da peça. */
/* Vamos fazer com que a peça (com border-radius: 50%) cubra a linha central */
/* E ajustar o z-index para a peça ficar acima das linhas */

.piece {
    z-index: 1; /* Garante que as peças fiquem acima das linhas */
    position: relative; /* Para que z-index funcione corretamente */
}


