Script

const boardElement = document.getElementById('board');
const piecesStockElement = document.getElementById('pieces-stock');
const removeAreaElement = document.getElementById('remove-area');

// Definindo o número de INTERSEÇÕES, não de casas.
// Para um tabuleiro 9x9 de interseções, teremos 8 "casas" visuais entre elas.
// Mas vamos modelar o grid para 9x9 posições de peças.
const boardGridSize = 9; // 9 linhas e 9 colunas de interseções

let draggedElement = null;
let isDraggingFromStock = false;
let isDraggingToBoard = false;

// Array para armazenar as posições das peças no tabuleiro lógico
// Cada elemento será { type: 'king', color: 'white', row: r, col: c }
const boardState = []; 

// Função para criar o tabuleiro de INTERSEÇÕES
function createBoard() {
    boardElement.innerHTML = ''; // Limpa o tabuleiro antes de recriar
    
    boardElement.style.gridTemplateColumns = `repeat(${boardGridSize}, 50px)`;
    boardElement.style.gridTemplateRows = `repeat(${boardGridSize}, 50px)`;
    // Ajusta o padding do board para acomodar as bordas grossas das linhas externas
    boardElement.style.padding = '10px'; 

    for (let r = 0; r < boardGridSize; r++) {
        for (let c = 0; c < boardGridSize; c++) {
            const square = document.createElement('div');
            square.classList.add('square');
            square.dataset.row = r;
            square.dataset.col = c;

            // Adiciona listeners para as casas (interseções)
            square.addEventListener('dragenter', handleDragEnter);
            square.addEventListener('dragleave', handleDragLeave);
            square.addEventListener('drop', handleDrop);
            square.addEventListener('dragover', handleDragOver);

            boardElement.appendChild(square);
        }
    }
    
    // Adiciona as linhas CSS via JavaScript para garantir compatibilidade e controle
    addLinesToBoard();
}

// Função para adicionar as linhas visuais ao tabuleiro
function addLinesToBoard() {
    // Remove linhas existentes para evitar duplicação
    document.querySelectorAll('.board-line').forEach(line => line.remove());

    const boardRect = boardElement.getBoundingClientRect();
    const squareSize = 50; // O mesmo tamanho definido no CSS para cada célula
    const gridSize = boardGridSize; // 9x9

    // Adiciona linhas verticais
    for (let c = 0; c < gridSize; c++) {
        const line = document.createElement('div');
        line.classList.add('board-line');
        line.style.position = 'absolute';
        line.style.width = c === 0 || c === gridSize - 1 ? '2px' : '1px'; // Borda grossa nas extremidades
        line.style.backgroundColor = c === 0 || c === gridSize - 1 ? '#333' : '#888'; // Cor da linha
        line.style.left = `${c * squareSize + (c === 0 ? 10 : (c === gridSize - 1 ? -1 : 0)) }px`; // Ajuste de posição, adicionando padding e considerando espessura da linha
        line.style.top = '10px'; // Começa após o padding superior
        line.style.height = `${gridSize * squareSize}px`; // Altura total do grid
        line.style.zIndex = '0';
        boardElement.appendChild(line);
    }

    // Adiciona linhas horizontais
    for (let r = 0; r < gridSize; r++) {
        const line = document.createElement('div');
        line.classList.add('board-line');
        line.style.position = 'absolute';
        line.style.height = r === 0 || r === gridSize - 1 ? '2px' : '1px'; // Borda grossa nas extremidades
        line.style.backgroundColor = r === 0 || r === gridSize - 1 ? '#333' : '#888'; // Cor da linha
        line.style.top = `${r * squareSize + (r === 0 ? 10 : (r === gridSize - 1 ? -1 : 0)) }px`; // Ajuste de posição
        line.style.left = '10px'; // Começa após o padding esquerdo
        line.style.width = `${gridSize * squareSize}px`; // Largura total do grid
        line.style.zIndex = '0';
        boardElement.appendChild(line);
    }
}

// Adaptação para adicionar peças nas INTERSEÇÕES (centradas na div '.square')
function placePieceOnBoard(pieceData, row, col) {
    // Remove peça existente na mesma interseção, se houver
    const existingPieceElement = findPieceElement(row, col);
    if (existingPieceElement) {
        existingPieceElement.remove();
        // Remover do boardState também
        const index = boardState.findIndex(p => p.row === row && p.col === col);
        if (index !== -1) boardState.splice(index, 1);
    }

    const newPiece = document.createElement('div');
    newPiece.classList.add('piece');
    newPiece.dataset.type = pieceData.type;
    newPiece.dataset.color = pieceData.color;
    newPiece.dataset.row = row; // Armazena a posição lógica na peça
    newPiece.dataset.col = col;

    if (pieceData.type === 'king') {
        newPiece.classList.add('king');
        newPiece.textContent = '♔';
    } else { // Peão
        newPiece.classList.add('pawn');
        if (pieceData.color === 'white') {
            newPiece.classList.add('white');
            newPiece.textContent = '♙';
        } else {
            newPiece.classList.add('black');
            newPiece.textContent = '♟';
        }
    }
    
    newPiece.setAttribute('draggable', true);
    newPiece.addEventListener('dragstart', handleBoardPieceDragStart);
    newPiece.addEventListener('dragend', handleDragEnd);

    // Encontra a casa (interseção) correta no grid
    const targetSquare = boardElement.querySelector(`.square[data-row="${row}"][data-col="${col}"]`);
    if (targetSquare) {
        targetSquare.appendChild(newPiece); // Adiciona a peça à div da interseção
        
        // Adiciona ao estado do tabuleiro
        boardState.push({ ...pieceData, row, col });
    }
}

// Função auxiliar para encontrar o elemento de peça em uma determinada interseção
function findPieceElement(row, col) {
    return boardElement.querySelector(`.square[data-row="${row}"][data-col="${col}"] > .piece`);
}

// Função auxiliar para remover uma peça do estado lógico e visual
function removePieceFromBoard(row, col) {
    const pieceElement = findPieceElement(row, col);
    if (pieceElement) {
        pieceElement.remove();
        const index = boardState.findIndex(p => p.row === row && p.col === col);
        if (index !== -1) boardState.splice(index, 1);
        return true;
    }
    return false;
}

// Inicializa algumas peças no tabuleiro (exemplo)
function initializeBoard() {
    // Rei no centro (interseção 4,4 em um grid 9x9)
    placePieceOnBoard({ type: 'king', color: 'white' }, 4, 4);
    
    // Peões nas posições iniciais (exemplo)
    // Linhas de cima e de baixo, nas bordas e colunas centrais
    // Linha 0, colunas 1, 4, 7
    placePieceOnBoard({ type: 'pawn', color: 'black' }, 0, 1);
    placePieceOnBoard({ type: 'pawn', color: 'black' }, 0, 4);
    placePieceOnBoard({ type: 'pawn', color: 'black' }, 0, 7);
    // Linha 8, colunas 1, 4, 7
    placePieceOnBoard({ type: 'pawn', color: 'black' }, 8, 1);
    placePieceOnBoard({ type: 'pawn', color: 'black' }, 8, 4);
    placePieceOnBoard({ type: 'pawn', color: 'black' }, 8, 7);
    
    // Peões brancos nas laterais (exemplo)
    // Coluna 0, linhas 1, 4, 7
    placePieceOnBoard({ type: 'pawn', color: 'white' }, 1, 0);
    placePieceOnBoard({ type: 'pawn', color: 'white' }, 4, 0);
    placePieceOnBoard({ type: 'pawn', color: 'white' }, 7, 0);
    // Coluna 8, linhas 1, 4, 7
    placePieceOnBoard({ type: 'pawn', color: 'white' }, 1, 8);
    placePieceOnBoard({ type: 'pawn', color: 'white' }, 4, 8);
    placePieceOnBoard({ type: 'pawn', color: 'white' }, 7, 8);
}


// Manipula o início do arrasto de uma peça DO ESTOQUE
function handleStockDragStart(e) {
    if (e.target.classList.contains('piece')) {
        draggedElement = e.target;
        isDraggingFromStock = true;
        isDraggingToBoard = false;
        e.dataTransfer.effectAllowed = 'copy';
        e.dataTransfer.setData('text/plain', null); // Necessário para Firefox
        setTimeout(() => { draggedElement.style.opacity = '0.5'; }, 0);
    } else if (e.target.classList.contains('piece-container')) {
        const pieceInside = e.target.querySelector('.piece');
        if (pieceInside) {
            draggedElement = pieceInside;
            isDraggingFromStock = true;
            isDraggingToBoard = false;
            e.dataTransfer.effectAllowed = 'copy';
            e.dataTransfer.setData('text/plain', null);
            setTimeout(() => { draggedElement.style.opacity = '0.5'; }, 0);
        }
    }
}

// Manipula o início do arrasto de uma peça JÁ NO TABULEIRO
function handleBoardPieceDragStart(e) {
    if (e.target.classList.contains('piece')) {
        draggedElement = e.target;
        isDraggingFromStock = false; // Não é do estoque
        isDraggingToBoard = true;    // Estamos indo para algum lugar no tabuleiro
        
        // Armazena a posição atual da peça arrastada
        draggedElement.dataset.originalRow = draggedElement.dataset.row;
        draggedElement.dataset.originalCol = draggedElement.dataset.col;

        e.dataTransfer.effectAllowed = 'move';
        e.dataTransfer.setData('text/plain', null);
        setTimeout(() => { draggedElement.style.opacity = '0.5'; }, 0);
    }
}

// Manipula o fim do arrasto (comum para todos os casos)
function handleDragEnd() {
    if (draggedElement) {
        draggedElement.style.opacity = '1';
    }
    draggedElement = null;
    isDraggingFromStock = false;
    isDraggingToBoard = false;
    
    // Limpa indicações de drag-over em todas as áreas
    document.querySelectorAll('.drag-over').forEach(el => el.classList.remove('drag-over'));
}

// --- Manipuladores para o TABULEIRO (interseções) ---
function handleDragEnter(e) {
    e.preventDefault();
    if (e.target.classList.contains('square')) { // Verifica se é uma interseção
        e.target.classList.add('drag-over');
    }
}

function handleDragLeave(e) {
    if (e.target.classList.contains('square')) {
        e.target.classList.remove('drag-over');
    }
}

function handleDragOver(e) {
    e.preventDefault();
    if (e.target.classList.contains('square')) {
        e.target.classList.add('drag-over');
    }
}

// --- Manipuladores para a ÁREA DE REMOÇÃO ---
function handleRemoveDragEnter(e) {
    e.preventDefault();
    if (e.target.classList.contains('drop-target-area')) {
        e.target.classList.add('drag-over');
    }
}

function handleRemoveDragLeave(e) {
    if (e.target.classList.contains('drop-target-area')) {
        e.target.classList.remove('drag-over');
    }
}

function handleRemoveDragOver(e) {
    e.preventDefault();
    if (e.target.classList.contains('drop-target-area')) {
        e.target.classList.add('drag-over');
    }
}

// --- Manipulador DE SOLTAR ---
function handleDrop(e) {
    e.preventDefault();
    
    if (!draggedElement) {
        return; 
    }

    const pieceType = draggedElement.dataset.type;
    const pieceColor = draggedElement.dataset.color;

    // 1. Soltar em uma INTERSEÇÃO do TABULEIRO
    if (e.target.classList.contains('square')) {
        const targetSquare = e.target;
        const targetRow = parseInt(targetSquare.dataset.row);
        const targetCol = parseInt(targetSquare.dataset.col);

        // Se veio do ESTOQUE (isDraggingFromStock é true)
        if (isDraggingFromStock) {
            // Verifica se a interseção de destino está vazia
            if (!findPieceElement(targetRow, targetCol)) {
                placePieceOnBoard({ type: pieceType, color: pieceColor }, targetRow, targetCol);
            } else {
                console.log("Interseção ocupada!");
            }
        } 
        // Se veio do TABULEIRO (isDraggingToBoard é true)
        else if (isDraggingToBoard) {
            const originalRow = parseInt(draggedElement.dataset.originalRow);
            const originalCol = parseInt(draggedElement.dataset.originalCol);

            // Verifica se a interseção de destino está vazia E se não é a mesma posição
            if (!findPieceElement(targetRow, targetCol) && !(originalRow === targetRow && originalCol === targetCol)) {
                // Remove a peça da posição original
                removePieceFromBoard(originalRow, originalCol);
                // Coloca a peça na nova posição
                placePieceOnBoard({ type: pieceType, color: pieceColor, row: targetRow, col: targetCol }, targetRow, targetCol);
            } else if (originalRow === targetRow && originalCol === targetCol) {
                console.log("Peça retornou à sua posição original.");
                // Peça retorna à sua posição, não faz nada além de resetar flags.
            } else {
                console.log("Interseção de destino ocupada!");
                // Peça retorna à sua posição original
                draggedElement.dataset.row = originalRow;
                draggedElement.dataset.col = originalCol;
                // Não removemos a peça do tabuleiro lógico, apenas a visual.
                // Poderíamos restaurar a peça no lugar original se ela foi removida visualmente.
                const originalSquare = boardElement.querySelector(`.square[data-row="${originalRow}"][data-col="${originalCol}"]`);
                if(originalSquare) {
                    originalSquare.appendChild(draggedElement); // Reanexa no lugar original
                }
            }
        }
    } 
    // 2. Soltar na ÁREA DE REMOÇÃO
    else if (e.target.classList.contains('drop-target-area')) {
        if (draggedElement && !isDraggingFromStock) { // Só remove peças que vieram do tabuleiro
            const row = parseInt(draggedElement.dataset.row);
            const col = parseInt(draggedElement.dataset.col);
            removePieceFromBoard(row, col); // Remove visual e logicamente
            console.log(`Peça removida da interseção (${row}, ${col}).`);
        } else if (draggedElement && isDraggingFromStock) {
            console.log("Não é possível remover peças do estoque diretamente.");
        }
    }

    // Limpa o estado após a ação
    draggedElement = null;
    isDraggingFromStock = false;
    isDraggingToBoard = false;
    document.querySelectorAll('.drag-over').forEach(el => el.classList.remove('drag-over'));
}

