<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tabuleiro Tafl Interativo - Interseções</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <h1>Tabuleiro Tafl 9x9 (Interseções)</h1>

    <div class="controls-area">
        <div id="pieces-stock">
            <h2>Peças Disponíveis</h2>
            <div class="piece-container" id="king-white-stock">
                <div class="piece king" draggable="true" data-type="king" data-color="white">♔</div>
            </div>
            <div class="piece-container" id="pawn-black-stock">
                <div class="piece pawn black" draggable="true" data-type="pawn" data-color="black">♟</div>
            </div>
            <div class="piece-container" id="pawn-white-stock">
                <div class="piece pawn white" draggable="true" data-type="pawn" data-color="white">♙</div>
            </div>
        </div>

        <div id="remove-area">
            <h2>Remover Peça</h2>
            <div class="drop-target-area">
                Arraste peças para cá para removê-las.
            </div>
        </div>
    </div>

    <div id="board-container"> <div id="board">
            </div>
    </div>

    <script src="script.js"></script>
</body>
</html>


Style

body {
    font-family: sans-serif;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
